# 本体模型平台 — 环境变量配置

# === LLM ===
# coze-coding-dev-sdk 的 LLMClient 会自动获取模型凭证
# 如需覆盖默认模型，可设置：
# LLM_MODEL=doubao-seed-1-8-251228

# === 部署 ===
# 服务器端口（由沙箱环境自动注入，勿硬编码）
# DEPLOY_RUN_PORT=5000

# 项目域名（由沙箱环境自动注入）
# COZE_PROJECT_DOMAIN_DEFAULT=https://xxx.dev.coze.site

# === MCP Server ===
# 自定义 MCP Server 地址（默认 http://localhost:5000）
# MCP_SERVER_URL=http://localhost:5000
