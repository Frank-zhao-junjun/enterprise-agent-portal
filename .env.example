# Enterprise Agent Portal — 环境变量配置

# === LLM Provider（二选一即可）===

# Moonshot / Kimi（当前主要 Provider）
KIMI_API_KEY=your_kimi_api_key_here

# OpenRouter（备选 Provider）
OPENROUTER_API_KEY=your_openrouter_api_key_here

# === 部署 ===

# 服务器端口（默认 5000）
# PORT=5000

# === MCP Server ===

# 自定义 MCP Server 地址（默认 http://localhost:5000）
# MCP_SERVER_URL=http://localhost:5000

# === 可选 ===

# Feishu/Lark 集成
# FEISHU_APP_ID=
# FEISHU_APP_SECRET=
